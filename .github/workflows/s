name: IPTV Ultimate Sniffer

on:
  push:
  schedule:
    - cron: '0 */7 * * *'
  workflow_dispatch:

concurrency:
  group: iptv-sniffer
  cancel-in-progress: true

jobs:

  # =========================
  # VITRINA TV
  # =========================
  vitrina:
    runs-on: ubuntu-latest
    timeout-minutes: 20

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Playwright
        run: |
          pip install --no-cache-dir playwright
          playwright install chromium
          playwright install-deps chromium

      - name: Run Vitrina Sniffer
        run: python sniffer_vitrina.py

      - name: Save Vitrina Results
        run: |
          git config --local user.email "bot@gitverse.ru"
          git config --local user.name "Sniffer Bot"

          mkdir -p playlists/vitrina

          git add playlists/vitrina/ || true
          git add VITRINA_URL.txt || true

          if git diff --staged --quiet; then
            echo "Нет изменений Vitrina"
          else
            git commit -m "🔄 Vitrina update $(date '+%Y-%m-%d %H:%M')"

            git pull --rebase origin main || true
            git push origin HEAD:main

            echo "✅ Vitrina обновлен"
          fi

  # =========================
  # RUTUBE
  # =========================
  rutube:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Playwright
        run: |
          pip install --no-cache-dir playwright
          playwright install chromium
          playwright install-deps chromium

      - name: Run RuTube Sniffer
        run: python sniffer_rutube.py

      - name: Save RuTube Results
        run: |
          git config --local user.email "bot@gitverse.ru"
          git config --local user.name "Sniffer Bot"

          mkdir -p playlists/rutube

          git add playlists/rutube/ || true
          git add RUTUBE_URL.txt || true

          if git diff --staged --quiet; then
            echo "Нет изменений RuTube"
          else
            git commit -m "🔄 RuTube update $(date '+%Y-%m-%d %H:%M')"

            git pull --rebase origin main || true
            git push origin HEAD:main

            echo "✅ RuTube обновлен"
          fi

  # =========================
  # README
  # =========================
  readme:
    runs-on: ubuntu-latest
    needs: [vitrina, rutube]
    if: always()

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - name: Generate README
        run: |
          VITRINA_URL=$(cat VITRINA_URL.txt 2>/dev/null || echo "https://gitverse.ru/USERNAME/REPO/raw/branch/main/playlists/vitrina/vitrina.m3u")

          RUTUBE_URL=$(cat RUTUBE_URL.txt 2>/dev/null || echo "https://gitverse.ru/USERNAME/REPO/raw/branch/main/playlists/rutube/rutube.m3u")

          DATE=$(date '+%Y-%m-%d %H:%M:%S')

          cat > README.md << EOF
# 📺 IPTV Ultimate Sniffer

Автоматический сбор IPTV потоков.

## 🚀 Плейлисты

| Источник | Ссылка |
|---|---|
| Vitrina TV | $VITRINA_URL |
| RuTube | $RUTUBE_URL |

## 🔄 Обновление

Плейлисты обновляются автоматически каждые 7 часов.

Последнее обновление:
$DATE

## 📥 IPTV Плееры

- VLC
- Kodi
- TiviMate
- IPTV Smarters

EOF

      - name: Commit README
        run: |
          git config --local user.email "bot@gitverse.ru"
          git config --local user.name "Sniffer Bot"

          git add README.md

          if git diff --staged --quiet; then
            echo "README без изменений"
          else
            git commit -m "📝 README update $(date '+%Y-%m-%d %H:%M')"

            git pull --rebase origin main || true
            git push origin HEAD:main

            echo "✅ README обновлен"
          fi
