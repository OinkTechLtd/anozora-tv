name: IPTV Сниффер

on:
  schedule:
    - cron: '0 */7 * * *'  # Каждые 7 часов
  workflow_dispatch:        # Ручной запуск (ДОЛЖЕН РАБОТАТЬ!)
    inputs:
      run_vitrina:
        description: 'Запустить Vitrina TV'
        type: boolean
        default: true
      run_rutube:
        description: 'Запустить RuTube'
        type: boolean
        default: true

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ========== VITRINA TV ==========
  vitrina:
    runs-on: ubuntu-latest
    timeout-minutes: 20
    if: github.event_name == 'schedule' || (github.event_name == 'workflow_dispatch' && github.event.inputs.run_vitrina == 'true')
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Установка Playwright
        run: |
          pip install --no-cache-dir playwright
          playwright install chromium
          playwright install-deps chromium

      - name: Запуск Vitrina сниффера
        run: python sniffer_vitrina.py
        env:
          GITVERSE_REPOSITORY: ${{ github.repository }}
          GITVERSE_REF_NAME: ${{ github.ref_name }}

      - name: Сохранение Vitrina результатов
        run: |
          git config --local user.email "bot@gitverse.ru"
          git config --local user.name "Sniffer Bot"
          git add playlists/vitrina/ VITRINA_URL.txt
          
          if git diff --staged --quiet; then
            echo "Нет изменений в Vitrina"
          else
            git commit -m "🔄 Vitrina TV: $(date +'%Y-%m-%d %H:%M')"
            git pull --rebase origin ${{ github.ref_name }} || true
            git push origin HEAD:${{ github.ref_name }}
            echo "✅ Vitrina сохранено"
          fi

  # ========== RUTUBE ==========
  rutube:
    runs-on: ubuntu-latest
    timeout-minutes: 30
    if: github.event_name == 'schedule' || (github.event_name == 'workflow_dispatch' && github.event.inputs.run_rutube == 'true')
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Установка Playwright
        run: |
          pip install --no-cache-dir playwright
          playwright install chromium
          playwright install-deps chromium

      - name: Запуск RuTube сниффера
        run: python sniffer_rutube.py
        env:
          GITVERSE_REPOSITORY: ${{ github.repository }}
          GITVERSE_REF_NAME: ${{ github.ref_name }}

      - name: Сохранение RuTube результатов
        run: |
          git config --local user.email "bot@gitverse.ru"
          git config --local user.name "Sniffer Bot"
          git add playlists/rutube/ RUTUBE_URL.txt
          
          if git diff --staged --quiet; then
            echo "Нет изменений в RuTube"
          else
            git commit -m "🔄 RuTube: $(date +'%Y-%m-%d %H:%M')"
            git pull --rebase origin ${{ github.ref_name }} || true
            git push origin HEAD:${{ github.ref_name }}
            echo "✅ RuTube сохранено"
          fi

  # ========== СОЗДАНИЕ/ОБНОВЛЕНИЕ README.md ==========
  readme:
    runs-on: ubuntu-latest
    needs: [vitrina, rutube]
    if: always() && (github.event_name == 'schedule' || github.event_name == 'workflow_dispatch')
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITVERSE_TOKEN }}

      - name: Создание/обновление README.md
        run: |
          # Получаем ссылки из файлов
          VITRINA_URL=$(cat VITRINA_URL.txt 2>/dev/null || echo "https://gitverse.ru/${{ github.repository }}/raw/main/playlists/vitrina/vitrina.m3u")
          RUTUBE_URL=$(cat RUTUBE_URL.txt 2>/dev/null || echo "https://gitverse.ru/${{ github.repository }}/raw/main/playlists/rutube/rutube.m3u")
          TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
          
          cat > README.md << 'ENDMARKER'
