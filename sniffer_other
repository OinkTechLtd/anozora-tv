JUNK = ["mc.yandex","yastatic","google-analytics","googletagmanager","doubleclick","tns-counter"]
results = {}
current_ch = None

def is_junk(url): return any(j in url.lower() for j in JUNK)
def is_stream(url): return any(x in url.lower() for x in [".m3u8",".mpd",".ts",".m4s"])

def classify(url):
    u = url.lower()
    if ".mpd" in u: return "dash"
    if ".m3u8" in u: return "hls"
    if ".ts" in u: return "ts"
    if ".m4s" in u: return "m4s"
    return "other"

def clean_name(raw, ch):
    if not raw: return ch
    t = raw.strip()
    for n in ["смотреть онлайн","прямой эфир","live","rutube","онлайн","бесплатно","— rutube","| rutube"]:
        t = re.sub(n, "", t, flags=re.IGNORECASE).strip()
    return t.strip("—|·- ") or ch

async def grab(page, ch, vid):
    global current_ch
    current_ch = ch
    results[ch] = {"name": ch, "streams": []}

    async def on_resp(resp):
        if current_ch != ch: return
        url = resp.url
        if resp.status >= 400 or is_junk(url) or not is_stream(url): return
        entry = {"url": url, "type": classify(url)}
        if not any(s["url"] == url for s in results[ch]["streams"]):
            results[ch]["streams"].append(entry)

    page.on("response", on_resp)

    # Способ 1 — прямой эфир
    ok = False
    try:
        await page.goto(f"https://rutube.ru/live/video/{vid}/", timeout=NAV_TIMEOUT, wait_until="domcontentloaded")
        await page.wait_for_timeout(WAIT_MS)
        ok = len(results[ch]["streams"]) > 0
    except: pass

    # Способ 2 — embed
    if not ok:
        try:
            await page.goto(f"https://rutube.ru/play/embed/{vid}/", timeout=NAV_TIMEOUT, wait_until="domcontentloaded")
            await page.wait_for_timeout(WAIT_MS)
            ok = len(results[ch]["streams"]) > 0
        except: pass

    # Способ 3 — страница канала (ждём до 10 сек)
    if not ok:
        try:
            await page.goto(f"https://rutube.ru/video/{vid}/", timeout=NAV_TIMEOUT, wait_until="domcontentloaded")
            await page.wait_for_timeout(10000)
            ok = len(results[ch]["streams"]) > 0
        except: pass

    # Название
    try:
        title = await page.title()
        results[ch]["name"] = clean_name(title, ch)
    except: pass

    page.remove_listener("response", on_resp)
    return ok

async def main():
    global results
    results = {}
    ids = list(CHANNELS.items())

    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True, args=["--no-sandbox"])
        ctx = await browser.new_context(user_agent="Mozilla/5.0")
        page = await ctx.new_page()

        print(f"🔍 RUTUBE — {len(ids)} каналов")
        for i, (ch, vid) in enumerate(ids):
            print(f"[{i+1}/{len(ids)}] {ch}", end=" ", flush=True)
            ok = await grab(page, ch, vid)
            n = len(results[ch]["streams"])
            if ok: print(f"✅ {n} потоков | {results[ch]['name']}")
            else: print("❌ пропущен")

        await browser.close()

    os.makedirs(OUTPUT_DIR, exist_ok=True)
    m3u = os.path.join(OUTPUT_DIR, "rutube.m3u")
    count = 0
    with open(m3u, "w", encoding="utf-8") as f:
        f.write(f"#EXTM3U\n#SOURCE:rutube.ru\n#DATE:{datetime.utcnow().isoformat()}Z\n\n")
        for ch, _ in ids:
            streams = results.get(ch, {}).get("streams", [])
            if not streams: continue
            s = streams[0]
            name = results[ch].get("name", ch)
            mtype = "dash" if s["type"] == "dash" else "hls"
            f.write(f'#EXTINF:-1 group-title="RuTube",{name}\n')
            f.write("#EXTVLCOPT:http-referrer=https://rutube.ru/\n")
            if mtype == "dash":
                f.write("#KODIPROP:inputstreamaddon=inputstream.adaptive\n")
                f.write("#KODIPROP:inputstream.adaptive.manifest_type=dash\n")
            f.write(f"{s['url']}\n\n")
            count += 1
    print(f"✅ {count}/{len(ids)} → {m3u}")

if __name__ == "__main__":
    asyncio.run(main())
