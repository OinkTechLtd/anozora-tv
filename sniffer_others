# Мусор — аналитика и реклама
JUNK = [
    "stat-analytics", "mc.yandex", "counter.yadro",
    "google-analytics", "googletagmanager", "doubleclick",
    "yastatic.net", "bs.serving-sys", "api.adriver.ru",
]

results = {}

def init_ch(ch):
    if ch not in results:
        results[ch] = {
            "url": CHANNELS.get(ch),
            "stream": None,        # Первый найденный поток
            "type": None,
            "all": [],             # Все потоки
            "status": "pending"
        }

def is_junk(url):
    return any(j in url.lower() for j in JUNK)

def is_stream(url):
    """Проверить, это ли потоковый URL"""
    u = url.lower()
    return any(ext in u for ext in (".m3u8", ".mpd", ".ts", ".m4s"))

def get_stream_type(url):
    """Определить тип потока"""
    u = url.lower()
    if ".mpd" in u:
        return "dash"
    elif ".m3u8" in u:
        return "hls"
    elif ".ts" in u:
        return "ts"
    elif ".m4s" in u:
        return "m4s"
    return "unknown"

async def sniff_channel(page, ch_id, video_url):
    """Снифить потоки с одного видео канала"""
    init_ch(ch_id)
    
    if not video_url:
        results[ch_id]["status"] = "no_url"
        return
    
    first_stream_found = False
    
    def on_response(resp):
        nonlocal first_stream_found
        url = resp.url
        if resp.status >= 400 or is_junk(url) or not is_stream(url):
            return
        
        stream_type = get_stream_type(url)
        
        # Сохраняем ПЕРВЫЙ поток
        if results[ch_id]["stream"] is None and not first_stream_found:
            results[ch_id]["stream"] = url
            results[ch_id]["type"] = stream_type
            first_stream_found = True
            print(f"  ⚡ [FIRST] {ch_id}: {stream_type.upper()} → {url[:90]}")
        else:
            # Логируем остальные только если нашли первый
            if not first_stream_found:
                emoji = {"dash":"📦", "hls":"📺", "ts":"🎬", "m4s":"🎬", "unknown":"📡"}
                e = emoji.get(stream_type, "📡")
                print(f"  {e} [{stream_type:5s}] {ch_id}: {url[:90]}")
        
        # Сохраняем все потоки
        if url not in [s["url"] for s in results[ch_id]["all"]]:
            results[ch_id]["all"].append({"url": url, "type": stream_type})
    
    page.on("response", on_response)
    
    try:
        await page.goto(video_url, timeout=NAV_TIMEOUT, wait_until="domcontentloaded")
        await page.wait_for_timeout(WAIT_MS)
        results[ch_id]["status"] = "ok" if results[ch_id]["stream"] else "no_streams"
    except Exception as e:
        results[ch_id]["status"] = f"error: {str(e)[:40]}"
        print(f"  ❌ {ch_id}: {str(e)[:50]}")
    finally:
        page.remove_listener("response", on_response)

async def run():
    global results
    results = {}
    
    # Инициализируем все каналы
    for ch_id in CHANNELS.keys():
        init_ch(ch_id)
    
    async with async_playwright() as p:
        browser = await p.chromium.launch(
            headless=True,
            args=["--no-sandbox", "--disable-blink-features=AutomationControlled"]
        )
        context = await browser.new_context(
            user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64)",
            java_script_enabled=True,
        )
        page = await context.new_page()
        
        channels_list = [(ch_id, url) for ch_id, url in CHANNELS.items() if url]
        
        print(f"{'='*70}")
        print(f"📡 RuTube: {len(channels_list)} каналов")
        print(f"{'='*70}")
        
        for i, (ch_id, video_url) in enumerate(channels_list):
            print(f"\n[{i+1}/{len(channels_list)}] {ch_id:15s}", end=" ", flush=True)
            await sniff_channel(page, ch_id, video_url)
        
        await browser.close()

def get_manifest_type(stream_type):
    """Определить правильный тип манифеста для M3U"""
    if stream_type == "dash":
        return "dash"
    else:
        return "hls"

def save():
    os.makedirs(OUTPUT_DIR, exist_ok=True)
    
    # M3U плейлист (только ПЕРВЫЕ потоки!)
    m3u_path = os.path.join(OUTPUT_DIR, "rutube.m3u")
    count = 0
    
    with open(m3u_path, "w", encoding="utf-8") as f:
        f.write("#EXTM3U\n")
        f.write(f"#SOURCE:rutube.ru\n")
        f.write(f"#DATE:{datetime.utcnow().isoformat()}Z\n\n")
        
        for ch_id, data in sorted(results.items()):
            if not data["stream"]:
                continue
            
            stream_type = data["type"]
            manifest_type = get_manifest_type(stream_type)
            
            f.write(f'#EXTINF:-1 group-title="RuTube",{ch_id}\n')
            f.write(f"#EXTVLCOPT:http-referrer=https://rutube.ru/\n")
            if manifest_type == "dash":
                f.write(f"#KODIPROP:inputstreamaddon=inputstream.adaptive\n")
                f.write(f"#KODIPROP:inputstream.adaptive.manifest_type=dash\n")
            f.write(f"{data['stream']}\n\n")
            count += 1
    
    # JSON со всеми потоками
    json_path = os.path.join(OUTPUT_DIR, "streams.json")
    clean = {}
    for ch_id, data in results.items():
        clean[ch_id] = {
            "url": data["url"],
            "first_stream": {
                "url": data["stream"],
                "type": data["type"]
            } if data["stream"] else None,
            "all_streams": data["all"],
            "status": data["status"]
        }
    
    with open(json_path, "w", encoding="utf-8") as f:
        json.dump(clean, f, indent=2, ensure_ascii=False)
    
    # Текстовый отчет
    txt_path = os.path.join(OUTPUT_DIR, "report.txt")
    with open(txt_path, "w", encoding="utf-8") as f:
        f.write(f"RuTube Sniffer Report (41 channels)\n")
        f.write(f"Date: {datetime.utcnow().isoformat()}Z\n")
        f.write(f"{'='*70}\n\n")
        
        ok_count = sum(1 for d in results.values() if d["stream"])
        f.write(f"Каналов с потоками: {ok_count}/{len(results)}\n\n")
        
        for ch_id, data in sorted(results.items()):
            f.write(f"[{ch_id}]\n")
            f.write(f"  URL: {data['url']}\n")
            f.write(f"  Status: {data['status']}\n")
            if data["stream"]:
                f.write(f"  First: [{data['type'].upper()}] {data['stream'][:70]}\n")
                if data["all"]:
                    f.write(f"  All ({len(data['all'])} streams):\n")
                    for s in data["all"]:
                        f.write(f"    - [{s['type']}] {s['url'][:70]}\n")
            f.write(f"\n")
    
    print(f"\n{'='*70}")
    print(f"✅ Каналов в M3U: {count}")
    print(f"📁 M3U:    {m3u_path}")
    print(f"📁 JSON:   {json_path}")
    print(f"📁 Report: {txt_path}")
    
    return count

async def main():
    t0 = time.time()
